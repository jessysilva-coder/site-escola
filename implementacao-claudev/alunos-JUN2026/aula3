<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Aula 3 — Claude no Power BI | Implementação Claude T2</title>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Open+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --chat:    #d97757;
      --chat2:   #e8956a;
      --cwork:   #7c5cbf;
      --cwork2:  #9b7dd4;
      --code:    #c45c8a;
      --code2:   #d97aaa;
      --bg:      #0c0b0a;
      --card:    #1a1714;
      --card2:   #211e1a;
      --border:  #2e2822;
      --border2: #3d3630;
      --text:    #f0ebe4;
      --muted:   #8a7f74;
      --muted2:  #5e5650;
      --ok:      #4caf7d;
      --no:      #e07070;
      --part:    #d4a843;
      --radius:  12px;
      --hh:      64px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; scroll-padding-top: calc(var(--hh) + 12px); }
    body { font-family: 'Open Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; overflow-x: hidden; }

    body::before {
      content: ''; position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 0; opacity: .45;
    }
    body::after {
      content: ''; position: fixed; inset: 0;
      background-image: linear-gradient(rgba(255,255,255,.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.02) 1px, transparent 1px);
      background-size: 48px 48px; pointer-events: none; z-index: 0;
    }

    .wrap { position: relative; z-index: 1; max-width: 920px; margin: 0 auto; padding: 0 24px; }

    header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(17,15,13,.92);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      height: var(--hh);
    }
    .header-inner {
      height: var(--hh);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 28px; gap: 14px; flex-wrap: nowrap;
    }
    .header-inner img { height: 38px; object-fit: contain; flex-shrink: 0; }
    .logo-text-fb { font-family: 'Anton', sans-serif; font-size: 1rem; color: var(--text); flex-shrink: 0; }
    .logo-text-fb span { color: var(--chat); }
    .header-btns { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .hbtn {
      font-family: 'DM Mono', monospace; font-size: .62rem; letter-spacing: .09em; text-transform: uppercase;
      padding: 6px 13px; border-radius: 100px; text-decoration: none; transition: all .2s; white-space: nowrap; border: none; cursor: pointer;
    }
    .hbtn-back  { color: var(--muted); border: 1px solid var(--border2); background: transparent; }
    .hbtn-back:hover { color: var(--text); border-color: var(--muted); }
    .hbtn-pdf { background: var(--card2); color: var(--muted); border: 1px solid var(--border2); display: flex; align-items: center; gap: 5px; }
    .hbtn-pdf:hover { color: var(--text); border-color: var(--border2); }

    .hero { padding: 48px 0 32px; text-align: center; position: relative; }
    .hero::before {
      content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
      width: 680px; height: 300px;
      background: radial-gradient(ellipse at center, rgba(124,92,191,.15) 0%, rgba(217,119,87,.08) 35%, transparent 72%);
      pointer-events: none;
    }
    .hero-tag { font-family: 'DM Mono', monospace; font-size: .68rem; letter-spacing: .15em; color: var(--muted); text-transform: uppercase; margin-bottom: 12px; display: block; }
    h1 { font-family: 'Anton', sans-serif; font-size: clamp(1.9rem, 5vw, 3rem); font-weight: 400; line-height: 1.1; margin-bottom: 12px; letter-spacing: .02em; }
    .hero-sub { font-size: .92rem; color: var(--muted); line-height: 1.75; max-width: 680px; margin: 0 auto; }

    .section { padding: 44px 0; border-top: 1px solid var(--border); }
    .section-label { font-family: 'DM Mono', monospace; font-size: .63rem; letter-spacing: .18em; text-transform: uppercase; color: var(--muted2); margin-bottom: 6px; }
    h2 { font-family: 'Anton', sans-serif; font-size: clamp(1.3rem, 3vw, 1.8rem); font-weight: 400; letter-spacing: .03em; margin-bottom: 22px; }
    h3 { font-family: 'Anton', sans-serif; font-size: 1rem; font-weight: 400; letter-spacing: .02em; margin-bottom: 10px; }
    p { line-height: 1.72; }

    .index-nav { background: var(--card2); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 20px; margin-bottom: 40px; }
    .index-nav .idx-label { font-family: 'DM Mono', monospace; font-size: .63rem; letter-spacing: .15em; text-transform: uppercase; color: var(--muted2); margin-bottom: 12px; display: block; }
    .index-nav ul { list-style: none; columns: 2; gap: 24px; }
    .index-nav li { break-inside: avoid; margin-bottom: 6px; }
    .index-nav li a { font-size: .82rem; color: var(--muted); text-decoration: none; display: flex; align-items: center; gap: 6px; transition: color .2s; }
    .index-nav li a:hover { color: var(--text); }
    .index-nav li a::before { content: '→'; color: var(--muted2); font-size: .72rem; flex-shrink: 0; }

    .info-box { background: rgba(255,255,255,.03); border: 1px solid var(--border2); border-radius: var(--radius); padding: 13px 17px; display: flex; gap: 10px; align-items: flex-start; margin-bottom: 20px; }
    .info-box .ico { font-size: 1rem; flex-shrink: 0; margin-top: 2px; }
    .info-box p { font-size: .82rem; color: var(--muted); line-height: 1.65; }
    .info-box p strong { color: var(--text); }

    .card-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin-bottom: 18px; }
    .soft-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 16px; }
    .soft-card.orange { border-top: 3px solid var(--chat); }
    .soft-card.purple { border-top: 3px solid var(--cwork); }
    .soft-card.pink { border-top: 3px solid var(--code); }
    .soft-card h3 { font-size: 1.03rem; margin-bottom: 6px; color: var(--text); }
    .soft-card p { font-size: .8rem; color: var(--muted); line-height: 1.62; }

    .btn-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; }
    .action-btn {
      display: inline-flex; align-items: center; gap: 8px; border-radius: 100px; padding: 10px 15px;
      font-family: 'DM Mono', monospace; font-size: .63rem; letter-spacing: .08em; text-transform: uppercase;
      text-decoration: none; cursor: pointer; transition: all .2s; border: 1px solid var(--border2); color: var(--text); background: var(--card2);
    }
    .action-btn:hover { transform: translateY(-1px); border-color: rgba(217,119,87,.5); }
    .action-btn.primary { background: var(--chat); color: #fff; border-color: var(--chat2); }
    .action-btn.primary:hover { background: var(--chat2); }
    .action-btn.purple { background: rgba(124,92,191,.18); color: var(--cwork2); border-color: rgba(124,92,191,.35); }
    .action-btn.pink { background: rgba(196,92,138,.18); color: var(--code2); border-color: rgba(196,92,138,.35); }

    .compare-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 12px; margin-top: 16px; }
    .compare-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; }
    .compare-card h3 { color: var(--text); font-size: 1rem; margin-bottom: 6px; }
    .compare-card p { font-size: .81rem; color: var(--muted); }

    .step-list { display: flex; flex-direction: column; gap: 12px; }
    .step { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    .step-head { display: flex; align-items: flex-start; gap: 14px; padding: 18px 18px 14px; border-bottom: 1px solid var(--border); }
    .step-num { width: 34px; height: 34px; flex-shrink: 0; border-radius: 50%; background: rgba(217,119,87,.14); border: 1px solid rgba(217,119,87,.35); color: var(--chat2); display: flex; align-items: center; justify-content: center; font-family: 'DM Mono', monospace; font-size: .72rem; font-weight: 600; }
    .step-copy h3 { font-size: 1.08rem; margin-bottom: 5px; }
    .step-copy p { font-size: .84rem; color: var(--muted); }
    .step-body { padding: 18px; }

    .mini-note { background: rgba(212,168,67,.08); border: 1px solid rgba(212,168,67,.24); border-radius: var(--radius); padding: 14px 16px; margin: 14px 0; }
    .mini-note strong { display: block; font-family: 'Anton', sans-serif; font-size: .98rem; font-weight: 400; color: #efd28b; letter-spacing: .03em; margin-bottom: 4px; }
    .mini-note p { font-size: .83rem; color: var(--muted); }

    .copy-line { display: flex; align-items: stretch; gap: 10px; flex-wrap: wrap; margin-top: 12px; }
    .copy-field, .path-input {
      flex: 1; min-width: 240px; background: #11100f; border: 1px solid var(--border2); color: #e7ddd3;
      border-radius: 10px; padding: 11px 13px; font-family: 'DM Mono', monospace; font-size: .78rem; outline: none;
    }
    .copy-field[readonly] { cursor: text; }
    .copy-btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 7px; border-radius: 100px; padding: 10px 14px;
      font-family: 'DM Mono', monospace; font-size: .61rem; letter-spacing: .08em; text-transform: uppercase;
      color: var(--text); border: 1px solid rgba(217,119,87,.35); background: rgba(217,119,87,.12); cursor: pointer; transition: all .2s;
    }
    .copy-btn:hover { background: rgba(217,119,87,.22); transform: translateY(-1px); }
    .copy-btn.copied { background: rgba(76,175,125,.16); border-color: rgba(76,175,125,.35); color: #bde8d1; }

    .prompt-box { background: #11100f; border: 1px solid var(--border2); border-radius: 11px; overflow: hidden; margin-top: 14px; }
    .prompt-tools { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 10px 12px; border-bottom: 1px solid var(--border); background: rgba(255,255,255,.02); }
    .prompt-tools span { font-family: 'DM Mono', monospace; font-size: .62rem; letter-spacing: .08em; text-transform: uppercase; color: var(--muted2); }
    .prompt-text {
      width: 100%; min-height: 220px; border: none; resize: vertical; outline: none;
      display: block; padding: 15px; background: transparent; color: #e7ddd3;
      font-family: 'DM Mono', monospace; font-size: .77rem; line-height: 1.7;
    }
    .prompt-text.mid { min-height: 300px; }
    .prompt-text.tall { min-height: 410px; }

    .path-builder { background: rgba(124,92,191,.08); border: 1px solid rgba(124,92,191,.24); border-radius: var(--radius); padding: 16px; margin-top: 16px; }
    .path-builder h3 { color: var(--cwork2); margin-bottom: 6px; }
    .path-builder p { font-size: .84rem; color: var(--muted); }

    .attention-box { background: rgba(224,112,112,.08); border: 1px solid rgba(224,112,112,.24); border-radius: var(--radius); padding: 15px 17px; margin-top: 16px; }
    .attention-box strong { display: block; font-family: 'Anton', sans-serif; font-weight: 400; letter-spacing: .03em; font-size: 1rem; color: #f1c0c0; margin-bottom: 6px; }
    .attention-box p { font-size: .84rem; color: var(--muted); }

    .figure-card { margin-top: 16px; }
    .figure-card img { width: 100%; height: auto; display: block; border-radius: 12px; }

    .lesson-block { background: linear-gradient(135deg, rgba(217,119,87,.12), rgba(124,92,191,.10)); border: 1px solid rgba(217,119,87,.28); border-radius: calc(var(--radius) + 4px); padding: 22px; }
    .lesson-block h2 { margin-bottom: 12px; }
    .lesson-block p { font-size: .88rem; color: var(--muted); }

    .material-card {
      display:flex; align-items:center; gap:16px; background:var(--card); border:1px solid var(--border2); border-radius:var(--radius);
      padding:18px 22px; text-decoration:none; transition:border-color .2s,transform .2s; margin-top: 14px;
    }
    .material-card:hover { border-color: rgba(217,119,87,.4); transform: translateY(-2px); }
    .material-icon { width:44px; height:44px; flex-shrink:0; border-radius:10px; background:rgba(66,133,244,.12); border:1px solid rgba(66,133,244,.25); display:flex; align-items:center; justify-content:center; font-size:1.3rem; }
    .material-copy { flex:1; }
    .material-title { font-family:'Anton',sans-serif; font-size:.95rem; font-weight:400; letter-spacing:.02em; color:var(--text); margin-bottom:3px; }
    .material-sub { font-size:.78rem; color:var(--muted); }
    .material-arrow { font-family:'DM Mono',monospace; font-size:.62rem; letter-spacing:.08em; text-transform:uppercase; color:var(--muted2); flex-shrink:0; }

    footer { border-top: 1px solid var(--border); padding: 24px 0 28px; text-align: center; margin-top: 48px; }
    footer p { font-size: .78rem; color: var(--muted2); }

    @media(max-width:780px) {
      .card-grid, .compare-grid { grid-template-columns: 1fr; }
      .step-head { flex-direction: column; }
      .header-inner { padding: 0 14px; gap: 8px; }
      .copy-line { flex-direction: column; }
      .copy-field, .path-input { min-width: 0; width: 100%; }
    }
    @media(max-width:640px) {
      .index-nav ul { columns: 1; }
      .hbtn { padding: 6px 10px; }
      .prompt-text, .prompt-text.mid, .prompt-text.tall { min-height: 420px; }
      .material-card { align-items:flex-start; }
      .material-arrow { display:none; }
    }
  </style>
</head>
