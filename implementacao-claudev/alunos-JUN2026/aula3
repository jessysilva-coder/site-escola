<script>
  function copyText(text, btn) {
    navigator.clipboard.writeText(text).then(() => {
      if (btn) {
        const original = btn.innerHTML;
        btn.classList.add('copied');
        btn.innerHTML = '✓ Copiado';
        setTimeout(() => {
          btn.classList.remove('copied');
          btn.innerHTML = original;
        }, 1800);
      }
    });
  }

  function copyField(id, btn) {
    const field = document.getElementById(id);
    if (!field) return;
    copyText(field.value, btn);
  }

  function copyPrompt(id, btn) {
    const textarea = document.getElementById(id);
    if (!textarea) return;
    copyText(textarea.value, btn);
  }

  function buildConfig() {
    const field = document.getElementById('userExePath');
    const output = document.getElementById('configOutput');
    if (!field || !output) return;

    const raw = field.value.trim().replace(/^"|"$/g, '');
    const command = raw || 'C:\\Users\\Jéssica\\.vscode\\extensions\\analysis-services.powerbi-modeling-mcp-0.4.0-win32-x64\\server\\powerbi-modeling-mcp.exe';
    const config = {
      mcpServers: {
        'powerbi-modeling-mcp': {
          type: 'stdio',
          command,
          args: ['--start', '--skipconfirmation'],
          env: {}
        }
      }
    };
    output.value = JSON.stringify(config, null, 2);
  }

  function downloadPDF() {
    const original = document.title;
    document.title = 'implementacao_claude_aula3';
    window.print();
    document.title = original;
  }

  buildConfig();
</script>

